# AI Live Notes - API Key Configuration
# 사용할 서비스의 API 키만 입력하면 됩니다 (입력한 프로바이더만 활성화)

# OpenAI (GPT-4o, etc.)
OPENAI_API_KEY=

# Google Gemini (Gemini 2.5 Pro, etc.)
GEMINI_API_KEY=

# Anthropic Claude (Sonnet, etc.)
ANTHROPIC_API_KEY=

# Ollama (로컬 LLM — 토큰 불필요, 기본 http://localhost:11434)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# HuggingFace 모델 캐시 (미설정 시 models/huggingface 사용)
# HF_HOME=./models/huggingface

# Fun-ASR-MLT-Nano: model.py는 Fun-ASR GitHub에만 있음.
# python scripts/setup_fun_asr.py 로 models/Fun-ASR 클론 필요.
# 상세: docs/FUNASR_SETUP.md
